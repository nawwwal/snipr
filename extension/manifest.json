{
  "manifest_version": 3,
  "name": "snipr",
  "version": "0.2.0",
  "description": "Full snipr editor from X/Twitter status pages — rip the video, keep the gold.",
  "key": "",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open snipr for this post",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "tabs",
    "activeTab",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://cdn.syndication.twimg.com/*",
    "https://video.twimg.com/*",
    "https://pbs.twimg.com/*",
    "https://video-ft.twimg.com/*",
    "https://snipr.naw.al/*"
  ]
}
